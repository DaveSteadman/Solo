{
  "header": {
    "title": "SoloGraph",
    "subtitle": "Concept vocabulary and connection graph",
    "actions": [
      { "type": "iconTextButton", "icon": "preview", "text": "Refresh", "color": "#8bd5ff", "action": "refresh" },
      { "type": "iconTextButton", "icon": "export", "text": "Export", "color": "#63d9a4", "action": "export" },
      { "type": "iconTextButton", "icon": "next", "text": "Import", "color": "#f0c060", "action": "import" }
    ]
  },
  "shell": {
    "fullWidth": true,
    "viewport": true,
    "viewportLock": true
  },
  "content": [
    {
      "type": "panels",
      "columns": 2,
      "resizable": true,
      "left": 38,
      "minPanelPixels": 260,
      "storageKey": "solograph.main-panels",
      "items": [
        {
          "type": "panel",
          "title": "Vocab",
          "viewport": true,
          "className": "page-panel--scroll",
          "items": [{ "type": "graphVocab" }]
        },
        {
          "type": "panel",
          "title": "Connections",
          "viewport": true,
          "className": "page-panel--scroll",
          "items": [{ "type": "graphConnections" }]
        }
      ]
    }
  ]
}
